# ==========================================
# Conclave Environment Configuration Example
# ==========================================

# -----------------
# API Credentials
# -----------------
# Get an API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------
# Model Configuration
# -----------------
# Model used for general cognition (e.g. agents, semantic compression)
GEMINI_MODEL=gemini-1.5-pro

# Model used specifically for Gemini Live API audio stream connections
GEMINI_LIVE_MODEL=gemini-1.5-pro

# Model used specifically for the Research Agent's inline search capabilities
GEMINI_SEARCH_MODEL=gemini-1.5-pro

# -----------------
# Server Settings
# -----------------
# HTTP Server Port for the UI dashboard
PORT=3000

# WebSocket Server Port for live event streaming
WS_PORT=3001

# -----------------
# Perception Tuning
# -----------------
# Audio processing sample rate
AUDIO_SAMPLE_RATE=16000

# Number of transcript segments to batch before semantic compression
COMPRESSION_BATCH_SIZE=3

# Time interval between semantic compression evaluations (ms)
COMPRESSION_INTERVAL_MS=5000

# -----------------
# Meeting Setup
# -----------------
MEETING_ID=demo-meeting-1
MEETING_OBJECTIVE="Technical design review for project Alpha"

# -----------------
# Attention Budget
# -----------------
ATTENTION_INITIAL_BUDGET=100
ATTENTION_REPLENISH_RATE=5
ATTENTION_BASE_COST=10
ATTENTION_COOLDOWN_MS=30000
ATTENTION_MIN_THRESHOLD=0.3
